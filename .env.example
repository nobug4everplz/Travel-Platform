# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=travel_platform_db
DB_USER=root
DB_PASS=

# App
APP_TIMEZONE=Asia/Taipei
APP_URL=http://localhost:8000

# AI Chat
# Get your key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Weather — Open-Meteo (free, no API key needed)
# No configuration required. Uses https://open-meteo.com/

# Mail (Google Workspace / Gmail SMTP)
# For Gmail: enable 2FA + generate App Password at https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME=Travel Platform
